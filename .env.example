# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Required for dependency autofix commits: Contents Read and write

# Vercel Sandbox
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# Optional model overrides (via Vercel AI Gateway)
AI_GATEWAY_API_KEY=

# Optional model overrides
AI_TRIAGE_MODEL=openai/gpt-5.4-mini
AI_REVIEW_MODEL=moonshotai/kimi-k2.6
AI_FALLBACK_MODEL=anthropic/claude-sonnet-4.6

