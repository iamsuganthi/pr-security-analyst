# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Required for dependency autofix commits: Contents Read and write

# Vercel Sandbox
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# Optional model overrides (via Vercel AI Gateway)
AI_GATEWAY_API_KEY=

# Optional model overrides
AI_TRIAGE_MODEL=openai/gpt-4o-mini
AI_REVIEW_MODEL=openai/gpt-4o
AI_FALLBACK_MODEL=anthropic/claude-3-5-haiku-latest

# Semgrep SAST (optional — off by default; GitHub PR reviews work without it)
# SECUREREVIEW_ENABLE_SEMGREP=true

# Auto-commit OSV dependency fixes to the PR branch (default: on)
# SECUREREVIEW_AUTOFIX_DEPS=false

# Live agent demo (npm run demo)
# SANDBOX_TEST_REPO=https://github.com/iamsuganthi/demo.git
# SANDBOX_TEST_REV=main
# GITHUB_TOKEN=   # only for private repos
